# FirstHx intake — credentials from your FirstHx account
FIRSTHX_INTAKE_BASE_URL=https://ca-staging.firsthx.com/intake/v1
FIRSTHX_INTAKE_SITE_ID=REPLACE_ME
FIRSTHX_INTAKE_USERNAME=REPLACE_ME
FIRSTHX_INTAKE_PASSWORD=REPLACE_ME
FIRSTHX_INTAKE_PLAN_ID=REPLACE_ME

# Clerk — create a project at https://clerk.com and copy these from the API keys page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Auth routes (match the file paths under src/app/)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Where Clerk sends the user after sign-in / sign-up completes
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app
