# FirstHx intake — credentials from your FirstHx account
FIRSTHX_INTAKE_BASE_URL=https://ca-staging.firsthx.com/intake/v1
FIRSTHX_INTAKE_SITE_ID=REPLACE_ME
FIRSTHX_INTAKE_USERNAME=REPLACE_ME
FIRSTHX_INTAKE_PASSWORD=REPLACE_ME
FIRSTHX_INTAKE_PLAN_ID=REPLACE_ME

# Clerk — create a project at https://clerk.com and copy these from the API keys page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Auth routes (match the file paths under src/app/)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Where Clerk sends the user after sign-in / sign-up completes
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# --- Local development (Docker Postgres) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/team_conflict

# --- Production (Vercel + Cloud SQL IAM) ---
# When these are set, src/lib/db.ts switches to the Cloud SQL Connector + IAM auth path.
# DATABASE_URL above is still required by the Prisma schema, but is unused at runtime.
# CLOUD_SQL_INSTANCE_CONNECTION_NAME=<project>:<region>:<instance>
# CLOUD_SQL_DATABASE=team_conflict
# CLOUD_SQL_IAM_USER=<service-account>@<project>.iam
# GOOGLE_APPLICATION_CREDENTIALS_JSON=<service-account-key-json>
